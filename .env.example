# Choose "deepseek" or "gemini". Never place API keys in React source files.
AI_PROVIDER=deepseek

# Create this key in the DeepSeek API platform.
DEEPSEEK_API_KEY=replace_with_your_key

# Current recommended options: deepseek-v4-flash or deepseek-v4-pro.
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional Gemini fallback.
GEMINI_API_KEY=replace_with_your_key

# Fish Audio voices. Keep this server-side only; never put it in React code.
FISH_API_KEY=e30e0d980fc94aa69177162b5f22d0be
FISH_MODEL=s2.1-pro-free
FISH_LATENCY=balanced

# Use Fish Audio voice model IDs from your Fish Audio account.
# Example library roles:
# Selene: meditative female
# Adrian: steady narrator
# Sarah: engaged speaker
# Ethan: curious explainer
# Laura: confident female narrator
# Jordan: motivational speaker
# Hannah: conversation specialist
FISH_DEFAULT_VOICE_ID=replace_with_default_voice_model_id
FISH_VOICE_PRIYA=replace_with_priya_voice_model_id
FISH_VOICE_MARCUS=replace_with_marcus_voice_model_id
FISH_VOICE_ELENA=replace_with_elena_voice_model_id
FISH_VOICE_ZANELE=replace_with_zanele_voice_model_id
FISH_VOICE_TOM=replace_with_tom_voice_model_id
FISH_VOICE_NALEDI=replace_with_naledi_voice_model_id
